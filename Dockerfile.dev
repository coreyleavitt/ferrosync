FROM rust:1.94-bookworm
RUN apt-get update && apt-get install -y rsync openssh-client pkg-config libssl-dev acl attr && rm -rf /var/lib/apt/lists/*
RUN mkdir -p /root/.ssh
COPY tests/fixtures/ssh/test_key /root/.ssh/id_ed25519
COPY tests/fixtures/ssh/test_key.pub /root/.ssh/id_ed25519.pub
RUN chmod 700 /root/.ssh && chmod 600 /root/.ssh/id_ed25519
# Disable strict host key checking for test containers
RUN echo "Host *\n  StrictHostKeyChecking no\n  UserKnownHostsFile /dev/null" > /root/.ssh/config
WORKDIR /workspace
