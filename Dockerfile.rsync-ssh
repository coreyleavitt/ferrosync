FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y rsync openssh-server attr && rm -rf /var/lib/apt/lists/*
RUN mkdir -p /run/sshd /root/.ssh
COPY tests/fixtures/ssh/test_key.pub /root/.ssh/authorized_keys
RUN chmod 700 /root/.ssh && chmod 600 /root/.ssh/authorized_keys
RUN sed -i 's/#PermitRootLogin.*/PermitRootLogin prohibit-password/' /etc/ssh/sshd_config
# ferrosync binary is shared via volume mount from build cache.
ENV PATH="/tmp/ferrosync-target/debug:${PATH}"
EXPOSE 22
CMD ["/usr/sbin/sshd", "-D", "-e"]
